#!/bin/sh -e
# Lists the latest modified files in the given directory or pwd
# up to a depth of 4
count=5
case "$1" in
(-a) all=true; shift;;
(--) shift;;
(-*) args="$1 $2"; shift 2;;
([0-9]) count=$(expr $1 \* 10); shift;;
esac

# BSD find lacks -printf; on those, format the mtime with stat instead.
case "$(uname)" in
(Darwin|*BSD)
	mtimes() { find "$1" -maxdepth 4 $args \
		-exec stat -f '%Sm %N' -t '%Y-%m-%d+%H:%M' {} +; };;
(*) mtimes() { find "$1" -maxdepth 4 $args -printf '%.16T+ %P\n'; };;
esac

for f in "${@:-$PWD}"
do test $# -gt 1 && { highlight "$f" || echo "$f"; }
	mtimes "$f" |
	sort -r | $(test "$all" && echo "less" || echo "head -$count")
done
